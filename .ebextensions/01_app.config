container_commands:
  00_diagnose:
    command: "echo '--- DIAGNOSTICS ---' && ls -la /var/app || echo 'no /var/app' && echo '--- /tmp perms ---' && ls -la /tmp && echo '--- touch test ---' && touch /tmp/writetest.txt && echo 'WRITE OK' && rm /tmp/writetest.txt && echo '--- python check ---' && cd /var/app/staging && source /var/app/venv/*/bin/activate && python -c \"import django, os; os.environ.setdefault('DJANGO_SETTINGS_MODULE','buildstock_project.settings'); django.setup(); from django.conf import settings; print('DB NAME:', settings.DATABASES['default']['NAME'])\""
    leader_only: true
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_fix_permissions:
    command: "chmod 666 /tmp/db.sqlite3 || true"
    leader_only: true
